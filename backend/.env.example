# Server configuration
PORT=8080

# SQLite database path (use a persistent volume path in production)
DB_PATH=./portfolio.db

# CORS — restrict to your frontend domain in production
# e.g. ALLOWED_ORIGIN=https://schulzdimitri.github.io
ALLOWED_ORIGIN=*

# SMTP configuration for the contact form email notification
# Leave empty to only store messages in the database (no email sent)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
CONTACT_TO_EMAIL=your@gmail.com
